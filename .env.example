# Copy this file to .env and fill in real values. .env is gitignored — never commit real credentials.

# Base URL of the running job-tracker instance.
# Local dev (docker compose on this machine):
JOB_TRACKER_URL=http://localhost:3000
# Production (TrueNAS/Portainer LAN address) — swap in when pointing at the real deployment:
# JOB_TRACKER_URL=http://<nas-ip>:3000

# Generate this from the app: Profile (click your username) -> API access -> Generate token.
# Scoped to the jobs API only — it cannot change your password or account settings, and
# doesn't touch the login endpoint at all, so there's no rate limit to worry about.
JOB_TRACKER_TOKEN=jt_...
